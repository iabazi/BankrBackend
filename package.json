{
    "name": "banking-api",
    "version": "1.0.0",
    "description": "Banking API for Android learners - Retrofit + Coroutines integration",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src test --ext .ts",
        "lint:fix": "eslint src test --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "banking",
        "api",
        "express",
        "typescript",
        "android",
        "retrofit"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "bcrypt": "^5.1.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "swagger-ui-express": "^4.6.3",
        "yaml": "^2.3.0",
        "pg": "^8.11.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.0",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/node": "^20.0.0",
        "@types/swagger-ui-express": "^4.1.3",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.46.0",
        "jest": "^29.5.0",
        "prettier": "^3.0.0",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.1.0",
        "@types/pg": "^8.10.0"
    }
}
